# All node_modules everywhere
**/node_modules/

# All vendor folders everywhere
**/vendor/

# Next.js
**/.next/

# Laravel
**/.env
**/storage/logs/*.log
**/storage/framework/cache/
**/storage/framework/sessions/
**/storage/framework/views/
**/bootstrap/cache/
**/database/database.sqlite

# Arkzen generated — rebuilt automatically on engine start
# These are all outputs of the engine, never hand-written source
engine/frontend/arkzen/generated/
engine/frontend/app/*/

# Keep engine base page and layout
!engine/frontend/app/layout.tsx
!engine/frontend/app/page.tsx

# Backend generated — all of /Arkzen/ is engine output, NOT source
engine/backend/app/Models/Arkzen/
engine/backend/app/Http/Controllers/Arkzen/
engine/backend/app/Http/Requests/Arkzen/
engine/backend/database/migrations/arkzen/
engine/backend/database/seeders/arkzen/
engine/backend/routes/modules/

# Keep the engine controller — it IS hand-written source
!engine/backend/app/Http/Controllers/Arkzen/ArkzenEngineController.php

# Environment files
**/.env.local
**/.env.production

# Exported projects (developer decides what to push per project)
projects/

# OS
.DS_Store
Thumbs.db

# Logs
*.log